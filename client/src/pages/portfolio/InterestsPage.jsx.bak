import { useState, useEffect } from 'react'
import styled, { keyframes } from 'styled-components'
import { Heart, Plus, X, Save } from 'lucide-react'
import { portfolioService } from '../../services/portfolioService'
import toast from 'react-hot-toast'

const PageContainer = styled.div`
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  max-width: 800px;
  margin: 0 auto;
  
  @media (max-width: 768px) {
    gap: 1rem;
  }
`

const Header = styled.div`
  margin-bottom: 0.5rem;
`

const Title = styled.h1`
  font-size: 1.875rem;
  font-weight: 700;
  color: #0f172a;
  margin: 0 0 0.5rem 0;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  
  @media (max-width: 768px) {
    font-size: 1.5rem;
  }
`

const TitleIcon = styled.span`
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: linear-gradient(135deg, #ec4899 0%, #be185d 100%);
  color: white;
  border-radius: 0.5rem;
  font-weight: 600;
  font-size: 1.125rem;
  flex-shrink: 0;
  
  svg {
    width: 1.25rem;
    height: 1.25rem;
  }
`

const Subtitle = styled.p`
  color: #64748b;
  font-size: 0.95rem;
  margin: 0;
`

const InputSection = styled.div`
  display: flex;
  gap: 0.75rem;
  
  @media (max-width: 768px) {
    flex-direction: column;
  }
`

const InterestInput = styled.input`
  flex: 1;
  border: 1px solid #e2e8f0;
  border-radius: 0.5rem;
  padding: 0.625rem 0.75rem;
  font-size: 0.95rem;
  font-family: inherit;
  transition: all 0.2s ease;
  
  &:focus {
    outline: none;
    border-color: #ec4899;
    background-color: #fef2f9;
    box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.1);
  }
  
  @media (max-width: 768px) {
    width: 100%;
  }
`

const AddButton = styled.button`
  background: linear-gradient(135deg, #ec4899 0%, #be185d 100%);
  color: white;
  border: none;
  padding: 0.625rem 1.25rem;
  border-radius: 0.5rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.3s ease;
  font-size: 0.95rem;
  white-space: nowrap;
  
  &:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(236, 72, 153, 0.3);
  }
  
  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  
  svg {
    width: 1rem;
    height: 1rem;
  }
`

const InterestsContainer = styled.div`
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 0.75rem;
  padding: 1.5rem;
  min-height: 150px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  
  &:hover {
    box-shadow: 0 4px 12px rgba(236, 72, 153, 0.1);
  }
`

const InterestsGrid = styled.div`
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  width: 100%;
`

const InterestTag = styled.span`
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.625rem 1rem;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 500;
  transition: all 0.2s ease;
  border: 1.5px solid transparent;
  cursor: default;
  user-select: none;
  
  ${props => {
    const colors = [
      {
        bg: 'linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%)',
        text: '#1e40af',
        border: '#93c5fd',
        hover: 'linear-gradient(135deg, #93c5fd 0%, #60a5fa 100%)',
        hoverText: '#ffffff'
      },
      {
        bg: 'linear-gradient(135deg, #dcfce7 0%, #f0fdf4 100%)',
        text: '#15803d',
        border: '#86efac',
        hover: 'linear-gradient(135deg, #86efac 0%, #4ade80 100%)',
        hoverText: '#ffffff'
      },
      {
        bg: 'linear-gradient(135deg, #fef3c7 0%, #fefce8 100%)',
        text: '#b45309',
        border: '#fde047',
        hover: 'linear-gradient(135deg, #fde047 0%, #facc15 100%)',
        hoverText: '#ffffff'
      },
      {
        bg: 'linear-gradient(135deg, #f3e8ff 0%, #faf5ff 100%)',
        text: '#7e22ce',
        border: '#d8b4fe',
        hover: 'linear-gradient(135deg, #d8b4fe 0%, #c084fc 100%)',
        hoverText: '#ffffff'
      },
      {
        bg: 'linear-gradient(135deg, #fce7f3 0%, #fdf2f8 100%)',
        text: '#be185d',
        border: '#fbcfe8',
        hover: 'linear-gradient(135deg, #fbcfe8 0%, #f472b6 100%)',
        hoverText: '#ffffff'
      },
      {
        bg: 'linear-gradient(135deg, #e0e7ff 0%, #f0f4ff 100%)',
        text: '#4f46e5',
        border: '#c7d2fe',
        hover: 'linear-gradient(135deg, #c7d2fe 0%, #a5b4fc 100%)',
        hoverText: '#ffffff'
      }
    ]
    const colorIndex = props.index % colors.length
    const color = colors[colorIndex]
    return `
      background: ${color.bg};
      color: ${color.text};
      border-color: ${color.border};
      
      &:hover {
        background: ${color.hover};
        color: ${color.hoverText};
        border-color: ${color.hover};
        box-shadow: 0 4px 12px ${color.bg};
        transform: translateY(-2px);
      }
    `
  }}
`

const RemoveButton = styled.button`
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 0.25rem;
  transition: all 0.2s ease;
  
  &:hover {
    transform: scale(1.3);
  }
  
  svg {
    width: 0.875rem;
    height: 0.875rem;
  }
`

const EmptyState = styled.p`
  text-align: center;
  color: #64748b;
  font-size: 0.95rem;
  margin: 0;
`

const LoadingContainer = styled.div`
  display: flex;
  justify-content: center;
  padding: 3rem 1rem;
  color: #64748b;
`

const Spinner = styled.div`
  width: 1.25rem;
  height: 1.25rem;
  border: 3px solid #e2e8f0;
  border-top-color: #ec4899;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 0.5rem;
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
`

const InterestsPage = () => {
  const [interests, setInterests] = useState([])
  const [newInterest, setNewInterest] = useState('')
  const [loading, setLoading] = useState(true)
  const [saving, setSaving] = useState(false)
  const { success, error } = useToast()

  useEffect(() => {
    portfolioService.getInterests()
      .then(({ data }) => setInterests(Array.isArray(data) ? data : data?.interests || []))
      .catch(() => error('Failed to load interests'))
      .finally(() => setLoading(false))
  }, [])

  const handleAdd = () => {
    const trimmed = newInterest.trim()
    if (!trimmed) return error('Interest cannot be empty')
    if (interests.includes(trimmed)) return error('Interest already exists')
    setInterests(prev => [...prev, trimmed])
    setNewInterest('')
  }

  const handleRemove = (index) => setInterests(prev => prev.filter((_, i) => i !== index))

  const handleSave = async () => {
    setSaving(true)
    try {
      await portfolioService.updateInterests({ interests })
      success('Interests updated')
    } catch {
      error('Failed to save interests')
    } finally {
      setSaving(false)
    }
  }

  if (loading) return (
    <LoadingContainer>
      <Spinner /> Loading...
    </LoadingContainer>
  )

  return (
    <PageContainer>
      <Header>
        <Title>
          <TitleIcon><Heart /></TitleIcon>
          Interests
        </Title>
        <Subtitle>Add or remove your personal interests</Subtitle>
      </Header>

      <InputSection>
        <InterestInput
          placeholder="e.g., Photography, Hiking, Reading"
          value={newInterest}
          onChange={(e) => setNewInterest(e.target.value)}
          onKeyDown={(e) => e.key === 'Enter' && handleAdd()}
        />
        <AddButton onClick={handleAdd} disabled={!newInterest.trim()}>
          <Plus /> Add
        </AddButton>
        <AddButton onClick={handleSave} disabled={saving} style={{background: interests.length === 0 ? '#cbd5e1' : undefined}}>
          {saving ? 'Saving...' : 'Save'}
        </AddButton>
      </InputSection>

      <InterestsContainer>
        {interests.length === 0 ? (
          <EmptyState>No interests added yet. Add some above to get started!</EmptyState>
        ) : (
          <InterestsGrid>
            {interests.map((interest, index) => (
              <InterestTag key={index} index={index}>
                {interest}
                <RemoveButton onClick={() => handleRemove(index)} title="Remove">
                  <X />
                </RemoveButton>
              </InterestTag>
            ))}
          </InterestsGrid>
        )}
      </InterestsContainer>
    </PageContainer>
  )
}

export default InterestsPage
