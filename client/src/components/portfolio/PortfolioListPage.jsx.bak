import { useState, useEffect } from 'react'
import styled, { keyframes, css } from 'styled-components'
import { Plus, Pencil, Trash2, X, Save, ExternalLink, Github } from 'lucide-react'
import { portfolioService } from '../../services/portfolioService'
import toast from 'react-hot-toast'

/* ── Keyframes ──────────────────────────────────────────────── */
const fadeUp = keyframes`
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: translateY(0); }
`
const shimmer = keyframes`
  0%   { background-position: -1000px 0; }
  100% { background-position: 1000px 0; }
`
const slideDown = keyframes`
  from { opacity: 0; max-height: 0; }
  to   { opacity: 1; max-height: 1200px; }
`
const dotPulse = keyframes`
  0%,100% { box-shadow: 0 0 0 0 rgba(0,212,255,0.4); }
  50%      { box-shadow: 0 0 0 5px rgba(0,212,255,0); }
`

/* ── Page ────────────────────────────────────────────────────── */
const Page = styled.div`
  animation: ${fadeUp} 0.4s ease both;
`

const Header = styled.div`
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
`

const Title = styled.h1`
  font-size: 1.875rem;
  font-weight: 700;
  color: #0f172a;
  margin: 0;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  
  @media (max-width: 768px) {
    font-size: 1.5rem;
  }
`

const TitleIcon = styled.span`
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
  color: white;
  border-radius: 0.5rem;
  font-weight: 600;
  font-size: 1.125rem;
  flex-shrink: 0;
  
  svg {
    width: 1.25rem;
    height: 1.25rem;
  }
`

const ListContainer = styled.div`
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
`

const ListItem = styled.div`
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background: white;
  border: 1px solid #e2e8f0;
  border-radius: 0.75rem;
  padding: 1rem;
  transition: all 0.3s ease;
  
  &:hover {
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.1);
    border-color: #3b82f6;
    transform: translateY(-2px);
  }
`

const ItemContent = styled.div`
  flex: 1;
  min-width: 0;
`

const ItemTitle = styled.p`
  font-weight: 600;
  color: #0f172a;
  margin: 0 0 0.5rem 0;
  font-size: 1rem;
  word-break: break-word;
`

const ItemSubtitle = styled.p`
  font-size: 0.875rem;
  color: #64748b;
  margin: 0;
  word-break: break-word;
`

const ItemActions = styled.div`
  display: flex;
  gap: 0.5rem;
  margin-left: 1rem;
  flex-shrink: 0;
`

const IconButton = styled.button`
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.25rem;
  height: 2.25rem;
  border: 1px solid #e2e8f0;
  background: white;
  border-radius: 0.5rem;
  cursor: pointer;
  color: #64748b;
  transition: all 0.2s ease;
  
  &:hover {
    background-color: #f0f4f8;
    color: #3b82f6;
    border-color: #3b82f6;
  }
  
  &:active {
    transform: scale(0.95);
  }
  
  svg {
    width: 1.125rem;
    height: 1.125rem;
  }
  
  &.delete:hover {
    color: #ef4444;
    border-color: #ef4444;
    background-color: #fee2e2;
  }
`

const EmptyState = styled.div`
  text-align: center;
  padding: 3rem 1rem;
  background: white;
  border: 2px dashed #e2e8f0;
  border-radius: 0.75rem;
  color: #64748b;
  font-size: 1rem;
`

const PrimaryButton = styled.button`
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
  color: white;
  border: none;
  padding: 0.625rem 1.25rem;
  border-radius: 0.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 0.95rem;
  
  &:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }
  
  &:active {
    transform: translateY(0);
  }
  
  svg {
    width: 1rem;
    height: 1rem;
  }
  
  @media (max-width: 768px) {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
`

const LoadingContainer = styled.div`
  display: flex;
  justify-content: center;
  padding: 3rem 1rem;
  color: #64748b;
  font-size: 1rem;
`

const Spinner = styled.div`
  width: 1.25rem;
  height: 1.25rem;
  border: 3px solid #e2e8f0;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 0.5rem;
  
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
`

const ModalOverlay = styled.div`
  position: fixed;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 50;
  padding: 1rem;
`

const ModalContent = styled.div`
  background: white;
  border-radius: 0.75rem;
  max-width: 500px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: 0 20px 25px rgba(0, 0, 0, 0.15);
`

const ModalHeader = styled.div`
  padding: 1.5rem;
  border-bottom: 1px solid #e2e8f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
`

const ModalTitle = styled.h2`
  font-size: 1.25rem;
  font-weight: 700;
  color: #0f172a;
  margin: 0;
`

const ModalCloseButton = styled.button`
  background: none;
  border: none;
  color: #64748b;
  cursor: pointer;
  font-size: 1.5rem;
  padding: 0;
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s ease;
  
  &:hover {
    color: #0f172a;
  }
`

const ModalBody = styled.div`
  padding: 1.5rem;
`

const FormGroup = styled.div`
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  margin-bottom: 1.25rem;
`

const Label = styled.label`
  font-size: 0.875rem;
  font-weight: 600;
  color: #1e293b;
`

const FormInput = styled.input`
  border: 1px solid #e2e8f0;
  border-radius: 0.5rem;
  padding: 0.625rem 0.75rem;
  font-size: 0.95rem;
  font-family: inherit;
  transition: all 0.2s ease;
  
  &:focus {
    outline: none;
    border-color: #3b82f6;
    background-color: #f0f7ff;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
`

const FormSelect = styled.select`
  border: 1px solid #e2e8f0;
  border-radius: 0.5rem;
  padding: 0.625rem 0.75rem;
  font-size: 0.95rem;
  font-family: inherit;
  background: white;
  transition: all 0.2s ease;

  &:focus {
    outline: none;
    border-color: #3b82f6;
    background-color: #f0f7ff;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
`

const FormTextarea = styled.textarea`
  border: 1px solid #e2e8f0;
  border-radius: 0.5rem;
  padding: 0.625rem 0.75rem;
  font-size: 0.95rem;
  font-family: inherit;
  resize: vertical;
  min-height: 100px;
  transition: all 0.2s ease;
  
  &:focus {
    outline: none;
    border-color: #3b82f6;
    background-color: #f0f7ff;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  }
`

const ModalFooter = styled.div`
  display: flex;
  justify-content: flex-end;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  border-top: 1px solid #e2e8f0;
`

const SecondaryButton = styled.button`
  padding: 0.625rem 1.25rem;
  border: 1px solid #e2e8f0;
  background: white;
  color: #64748b;
  border-radius: 0.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 0.95rem;
  
  &:hover {
    background-color: #f0f4f8;
    color: #0f172a;
  }
`

const SaveButton = styled.button`
  padding: 0.625rem 1.25rem;
  background: linear-gradient(135deg, #3b82f6 0%, #1e40af 100%);
  color: white;
  border: none;
  border-radius: 0.5rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  font-size: 0.95rem;
  
  &:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
  }
  
  &:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
`

/**
 * Generic CRUD list page for portfolio sections.
 * @param {string} title - Page heading
 * @param {object} service - { getAll, create, update, delete }
 * @param {Array}  fields  - [{ name, label, type?, required?, rows? }]
 * @param {React.ReactNode} icon - Icon to display in header
 */
const PortfolioListPage = ({ title, service, fields, icon }) => {
  const [items, setItems] = useState([])
  const [loading, setLoading] = useState(true)
  const [modalOpen, setModalOpen] = useState(false)
  const [editing, setEditing] = useState(null)
  const [form, setForm] = useState({})
  const [saving, setSaving] = useState(false)
  const [fileUploads, setFileUploads] = useState({})
  const [filePreviews, setFilePreviews] = useState({})
  const { confirm, ConfirmModal } = useConfirm()

  useEffect(() => {
    service.getAll()
      .then(({ data }) => setItems(data || []))
      .catch(() => {})
      .finally(() => setLoading(false))
  }, [])

  const openCreate = () => {
    setEditing(null)
    setForm(Object.fromEntries(fields.map(f => [f.name, ''])))
    setFileUploads({})
    setFilePreviews({})
    setModalOpen(true)
  }

  const openEdit = (item) => {
    setEditing(item)
    const initial = Object.fromEntries(fields.map((f) => {
      const value = item[f.name] ?? item[`${f.name}Url`] ?? ''
      return [f.name, value]
    }))
    setForm(initial)

    const previewState = Object.fromEntries(fields
      .filter(f => f.type === 'file')
      .map(f => {
        const val = item[f.name] ?? item[`${f.name}Url`] ?? ''
        return [f.name, val]
      })
      .filter(([,v]) => !!v)
    )
    setFilePreviews(previewState)
    setFileUploads({})
    setModalOpen(true)
  }

  const handleFileChange = (fieldName) => (e) => {
    const file = e.target.files?.[0]
    if (!file) {
      setFileUploads(prev => ({ ...prev, [fieldName]: null }))
      setFilePreviews(prev => {
        const next = { ...prev }
        delete next[fieldName]
        return next
      })
      return
    }

    const previewUrl = URL.createObjectURL(file)
    setFileUploads(prev => ({ ...prev, [fieldName]: file }))
    setFilePreviews(prev => ({ ...prev, [fieldName]: previewUrl }))
    setForm(prev => ({ ...prev, [fieldName]: file.name }))
  }

  useEffect(() => {
    return () => {
      Object.values(filePreviews).forEach((url) => {
        if (typeof url === 'string' && url.startsWith('blob:')) {
          URL.revokeObjectURL(url)
        }
      })
    }
  }, [filePreviews])

  const handleSubmit = async (e) => {
    e.preventDefault()
    setSaving(true)
    try {
      const payload = { ...form }

      for (const field of fields.filter(f => f.type === 'file')) {
        const file = fileUploads[field.name]
        if (file) {
          const uploadData = new FormData()
          uploadData.append('image', file)
          const { data } = await portfolioService.uploadImage(uploadData)
          payload[field.name] = data.key
        }
      }

      if (fields.some(f => f.name === 'tech' && typeof payload.tech === 'string')) {
        payload.tech = payload.tech.split(',').map(t => t.trim()).filter(Boolean)
      }

      if (editing) {
        const { data } = await service.update(editing._id, payload)
        setItems(prev => prev.map(i => i._id === data._id ? data : i))
        toast.success('Updated')
      } else {
        const { data } = await service.create(payload)
        setItems(prev => [data, ...prev])
        toast.success('Created')
      }
      setModalOpen(false)
    } catch (err) {
      toast.error(err.response?.data?.message || 'Failed to save')
    } finally {
      setSaving(false)
    }
  }

  const handleDelete = async (id) => {
    const ok = await confirm({ title: `Delete ${title.slice(0, -1)}`, message: 'Are you sure?' })
    if (!ok) return
    try {
      await service.delete(id)
      setItems(prev => prev.filter(i => i._id !== id))
      toast.success('Deleted')
    } catch {
      toast.error('Failed to delete')
    }
  }

  if (loading) return (
    <LoadingContainer>
      <Spinner /> Loading...
    </LoadingContainer>
  )

  return (
    <>
      <PageContainer>
        <Header>
          <Title>
            {icon && <TitleIcon>{icon}</TitleIcon>}
            {title}
          </Title>
          <PrimaryButton onClick={openCreate}>
            <Plus /> Add
          </PrimaryButton>
        </Header>

        {items.length === 0 ? (
          <EmptyState>No {title.toLowerCase()} added yet. Create your first one!</EmptyState>
        ) : (
          <ListContainer>
            {items.map(item => (
              <ListItem key={item._id}>
                <ItemContent>
                  <ItemTitle>{item[fields[0]?.name] || 'Untitled'}</ItemTitle>
                  {fields[1] && (
                    <ItemSubtitle>{item[fields[1]?.name]}</ItemSubtitle>
                  )}
                  {fields.some(f => f.type === 'file' && (item[f.name] || item[`${f.name}Url`])) && (
                    <div style={{ marginTop: '0.6rem' }}>
                      <img
                        src={item[`${fields.find(f => f.type === 'file')?.name}Url`] || item[fields.find(f => f.type === 'file')?.name]}
                        alt="Preview"
                        style={{ width: '100%', maxHeight: '140px', borderRadius: '8px', objectFit: 'cover', border: '1px solid #E2E8F0' }}
                      />
                    </div>
                  )}
                </ItemContent>
                <ItemActions>
                  <IconButton onClick={() => openEdit(item)} title="Edit">
                    <Edit />
                  </IconButton>
                  <IconButton className="delete" onClick={() => handleDelete(item._id)} title="Delete">
                    <Trash2 />
                  </IconButton>
                </ItemActions>
              </ListItem>
            ))}
          </ListContainer>
        )}
      </PageContainer>

      {modalOpen && (
        <ModalOverlay onClick={() => !saving && setModalOpen(false)}>
          <ModalContent onClick={(e) => e.stopPropagation()}>
            <ModalHeader>
              <ModalTitle>{editing ? `Edit ${title.slice(0, -1)}` : `Add ${title.slice(0, -1)}`}</ModalTitle>
              <ModalCloseButton onClick={() => !saving && setModalOpen(false)}>×</ModalCloseButton>
            </ModalHeader>
            <ModalBody>
              <form onSubmit={handleSubmit}>
                {fields.map(field => {
                  const currentValue = form[field.name] || ''
                  const previewValue = filePreviews[field.name] || currentValue

                  return (
                    <FormGroup key={field.name}>
                      <Label htmlFor={field.name}>{field.label}</Label>

                      {field.type === 'file' ? (
                        <>
                          <input
                            id={field.name}
                            type="file"
                            accept="image/*"
                            onChange={handleFileChange(field.name)}
                            style={{ display: 'block', marginBottom: '0.55rem' }}
                          />
                          {previewValue && (
                            <img
                              src={previewValue}
                              alt={field.label}
                              style={{
                                maxWidth: '100%',
                                maxHeight: '180px',
                                borderRadius: '8px',
                                border: '1px solid #E2E8F0',
                                objectFit: 'cover'
                              }}
                            />
                          )}
                        </>
                      ) : field.type === 'select' ? (
                        <FormSelect
                          id={field.name}
                          value={currentValue}
                          onChange={(e) => setForm(prev => ({ ...prev, [field.name]: e.target.value }))}
                          required={field.required}
                        >
                          <option value="">Choose...</option>
                          {field.options?.map((opt) => (
                            <option key={opt} value={opt}>{opt}</option>
                          ))}
                        </FormSelect>
                      ) : field.rows ? (
                        <FormTextarea
                          id={field.name}
                          value={currentValue}
                          onChange={(e) => setForm(prev => ({ ...prev, [field.name]: e.target.value }))}
                          rows={field.rows}
                          required={field.required}
                        />
                      ) : (
                        <FormInput
                          id={field.name}
                          type={field.type || 'text'}
                          value={currentValue}
                          onChange={(e) => setForm(prev => ({ ...prev, [field.name]: e.target.value }))}
                          required={field.required}
                        />
                      )}
                    </FormGroup>
                  )
                })}
                <ModalFooter>
                  <SecondaryButton type="button" onClick={() => setModalOpen(false)} disabled={saving}>
                    Cancel
                  </SecondaryButton>
                  <SaveButton type="submit" disabled={saving}>
                    {saving ? 'Saving...' : 'Save'}
                  </SaveButton>
                </ModalFooter>
              </form>
            </ModalBody>
          </ModalContent>
        </ModalOverlay>
      )}

      <ConfirmModal />
    </>
  )
}

export default PortfolioListPage
